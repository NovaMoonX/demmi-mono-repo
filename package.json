{
  "name": "demmi-monorepo",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace=@demmi/web",
    "dev:electron": "npm run dev --workspace=@demmi/electron",
    "dev:mobile": "npm run dev --workspace=@demmi/mobile",
    "build:web": "npm run build --workspace=@demmi/web",
    "build:electron": "npm run build --workspace=@demmi/electron",
    "lint:web": "npm run lint --workspace=@demmi/web",
    "lint": "npm run lint --workspaces --if-present",
    "test:web": "npm run test --workspace=@demmi/web",
    "test:electron": "npm run test --workspace=@demmi/electron",
    "test:mobile": "npm run test --workspace=@demmi/mobile",
    "test": "npm run test --workspaces --if-present",
    "install:all": "npm install"
  }
}
